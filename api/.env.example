PORT=3001
MONGO_URI=mongodb://127.0.0.1:27017/codearena
REDIS_URL=redis://127.0.0.1:6379
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=codearena

# prod: generate via e.g. `openssl rand -base64 32`; never reuse this placeholder
JWT_SECRET=change-me-in-prod-use-a-long-random-string
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000

# Google Gemini API (free tier) — server-side only, never exposed to the
# frontend. Generate a key at Google AI Studio; never commit a real value.
# NOTE: free-tier requests may be used by Google to improve its products —
# see ARCHITECTURE.md §9 for the tradeoff this accepts for a $0 hint feature.
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
HINT_MAX_TOKENS=600
# Deliberately conservative: published free-tier RPM/RPD figures could not be
# independently verified during planning (Google's docs point to an
# authenticated AI Studio dashboard, not a static page) and limits can change
# without notice. Tune this up only after checking the project's own AI
# Studio rate-limit dashboard.
HINT_GLOBAL_RPM_LIMIT=8
# Confirmed via a live 429 during Phase 6 testing: gemini-2.5-flash-lite's real
# free-tier cap is 20 requests/day/project (GenerateRequestsPerDayPerProjectPerModel-
# FreeTier), not the ~1,000/day figure originally assumed. Keep this under 20.
HINT_GLOBAL_DAILY_LIMIT=18

# Nakalchi integration (plagiarism detection) — off by default. When true, the other
# five vars below are required at boot (see api/src/config/env.ts's fail-fast check).
INTEGRITY_ANALYSIS_ENABLED=false
# Shared secret: must equal Nakalchi's CODEARENA_SERVICE_TOKEN. Protects
# GET /internal/contests/:id/submissions (X-Internal-Token header).
INTERNAL_SERVICE_TOKEN=dev-local-internal-service-token
# Nakalchi's api service — worker/src/integrity.ts POSTs here.
NAKALCHI_API_BASE_URL=http://localhost:3000
# Must equal one of Nakalchi's API_KEYS.
NAKALCHI_API_KEY=dev-local-api-key
# Shared secret: must equal Nakalchi's WEBHOOK_SECRET. Verifies the signed
# POST /internal/webhooks/nakalchi callback (X-Nakalchi-Signature header).
NAKALCHI_WEBHOOK_SECRET=dev-local-webhook-secret-change-me
# This CodeArena instance's own reachable address — sent to Nakalchi as
# `callbackUrl` so it knows where to POST the signed result. IMPORTANT: this is
# dialed back by Nakalchi's OWN worker process, not by anything in this repo — if
# Nakalchi runs in Docker (its own established local-dev convention) while this api
# runs on the host, `localhost` here resolves to Nakalchi's container, not this
# machine, and every webhook delivery attempt fails with ECONNREFUSED (hit for real
# during Phase 6's E2E — see Nakalchi's docs/e2e-codearena.md and BUGLOG.md). Use
# `http://host.docker.internal:<this-api's-port>/internal/webhooks/nakalchi` in that
# case; the plain localhost value below is only correct if Nakalchi ALSO runs on the
# host (not in Docker).
INTERNAL_WEBHOOK_CALLBACK_URL=http://localhost:3001/internal/webhooks/nakalchi
