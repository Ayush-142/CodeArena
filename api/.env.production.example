# Copy to api/.env.production and fill in real values (never commit the real file — already
# gitignored). Loaded by docker-compose.prod.yml's `api` service via `env_file:` — unlike the
# root .env.production, values here are NOT ${VAR}-substituted by Compose, so MONGO_URI/
# MINIO_ACCESS_KEY/MINIO_SECRET_KEY below must have the SAME literal values you generated for
# MONGO_ROOT_USERNAME/MONGO_ROOT_PASSWORD/MINIO_ROOT_USER/MINIO_ROOT_PASSWORD in the root
# .env.production — see DEPLOY.md for the exact sequence.

PORT=3001

# mongo/redis/minio are the compose SERVICE NAMES (Docker's internal DNS), not 127.0.0.1 — this
# is the one thing that differs mechanically from local dev's api/.env.example.
MONGO_URI=mongodb://<MONGO_ROOT_USERNAME>:<MONGO_ROOT_PASSWORD>@mongo:27017/codearena?authSource=admin
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<same value as MINIO_ROOT_USER in the root .env.production>
MINIO_SECRET_KEY=<same value as MINIO_ROOT_PASSWORD in the root .env.production>
MINIO_BUCKET=codearena

# Generate via: openssl rand -hex 32
JWT_SECRET=changeme-generate-with-openssl-rand
# true in production — Caddy terminates TLS, the browser only ever sees HTTPS, and a Secure
# cookie is what actually enforces that (see api/src/middleware/auth.ts).
COOKIE_SECURE=true
# The public HTTPS origin the frontend is served from (no trailing slash, no /api suffix —
# this is CORS's allowlist, not the API URL itself).
CORS_ORIGIN=https://changeme.duckdns.org

# Google Gemini API (free tier) — server-side only, never exposed to the frontend. Generate a
# key at Google AI Studio; never commit a real value. NOTE: free-tier requests may be used by
# Google to improve its products — see ARCHITECTURE.md §9 for the tradeoff this accepts for a
# $0 hint feature.
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
HINT_MAX_TOKENS=600
HINT_GLOBAL_RPM_LIMIT=8
# Confirmed via a live 429 during Phase 6 testing: gemini-2.5-flash-lite's real free-tier cap
# is 20 requests/day/project. Keep this under 20 — it's the platform-wide daily hint budget,
# shared across every user (see ARCHITECTURE.md §9).
HINT_GLOBAL_DAILY_LIMIT=18

# Nakalchi integration (plagiarism detection) — off by default. See api/.env.example for
# what each var does; values here must match whatever Nakalchi's own prod deployment uses.
INTEGRITY_ANALYSIS_ENABLED=false
INTERNAL_SERVICE_TOKEN=<same value as Nakalchi's CODEARENA_SERVICE_TOKEN>
NAKALCHI_API_BASE_URL=https://changeme-nakalchi.duckdns.org
NAKALCHI_API_KEY=<same value as one of Nakalchi's API_KEYS>
NAKALCHI_WEBHOOK_SECRET=<same value as Nakalchi's WEBHOOK_SECRET>
INTERNAL_WEBHOOK_CALLBACK_URL=https://changeme.duckdns.org/internal/webhooks/nakalchi

NODE_ENV=production
