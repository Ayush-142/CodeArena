# Copy to worker/.env.production and fill in real values (never commit the real file — already
# gitignored). Loaded by docker-compose.prod.yml's `worker` service via `env_file:`. Same
# not-${VAR}-substituted caveat as api/.env.production.example — MONGO_URI/MINIO_ACCESS_KEY/
# MINIO_SECRET_KEY must match the literal values in the root .env.production. See DEPLOY.md.

REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<same value as MINIO_ROOT_USER in the root .env.production>
MINIO_SECRET_KEY=<same value as MINIO_ROOT_PASSWORD in the root .env.production>
MINIO_BUCKET=codearena
MONGO_URI=mongodb://<MONGO_ROOT_USERNAME>:<MONGO_ROOT_PASSWORD>@mongo:27017/codearena?authSource=admin

NODE_ENV=production

# Optional — defaults to 20000 (20s) if unset. See worker/src/sandbox.ts and
# worker/judge/Dockerfile's precompiled-header comment for why 20s: real bits/stdc++.h
# submissions compile in well under 1s against the precompiled header; this is belt-and-braces
# headroom, not the expected case.
# COMPILE_TIMEOUT_MS=20000

# Required if INTEGRITY_ANALYSIS_ENABLED=true (see api/.env.production.example). Found missing
# from this file during Nakalchi's Phase 7 production-hardening pass: api/src/config/env.ts's
# boot-time check only validates these on the api process, but the actual outbound call to
# Nakalchi happens here, in worker/src/integrity.ts, which reads them independently with only a
# runtime throw (no boot-time guard) — so api could boot cleanly while every integrity job still
# failed for want of these three vars on the worker specifically. Same values as api's.
NAKALCHI_API_BASE_URL=http://nakalchi-api:3000
NAKALCHI_API_KEY=<same value as NAKALCHI_API_KEY in api/.env.production>
INTERNAL_WEBHOOK_CALLBACK_URL=http://api:3001/internal/webhooks/nakalchi
