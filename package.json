{
  "name": "codearena",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "api",
    "frontend",
    "worker"
  ],
  "scripts": {
    "dev:api": "npm --workspace api run dev",
    "dev:worker": "npm --workspace worker run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "seed": "npm --workspace api run seed",
    "reset-demo": "npm --workspace api run reset-demo",
    "simulate-contest": "npm --workspace api run simulate-contest",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "typescript-eslint": "^8.63.0"
  }
}
