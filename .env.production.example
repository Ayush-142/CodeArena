# Root-level secrets — consumed by docker-compose.prod.yml's own ${VAR} interpolation (the
# mongo/minio services' `environment:` blocks, the frontend service's `build.args`, and Caddy's
# DOMAIN). NOT the same mechanism as `env_file:` (api/worker read their OWN .env.production
# files below — env_file values do not support ${VAR} substitution from this file).
#
# Copy to .env.production and fill in real values. Never commit the real file (already
# gitignored via `.env.*`). See DEPLOY.md for the exact `openssl rand` commands and the exact
# `docker compose ... --env-file .env.production ...` invocation that reads this file.

MONGO_ROOT_USERNAME=codearena
MONGO_ROOT_PASSWORD=changeme-generate-with-openssl-rand

MINIO_ROOT_USER=codearena
MINIO_ROOT_PASSWORD=changeme-generate-with-openssl-rand

# codearena-<name>.duckdns.org — see DEPLOY.md's DuckDNS section.
DOMAIN=changeme.duckdns.org

# Baked into the frontend's client bundle at BUILD time (see frontend/Dockerfile) — must be the
# public HTTPS URL Caddy serves, with /api appended (Caddy proxies /api/* to the api container).
NEXT_PUBLIC_API_URL=https://changeme.duckdns.org/api
