# Origin only — no trailing slash, no /api suffix. API paths are added by lib/api.ts.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Nakalchi integration — origin only, no trailing slash. Used by the contest admin
# Integrity section (app/admin/contests/[id]/page.tsx) to deep-link into Nakalchi's
# report UI. Optional: the link is simply omitted if unset.
NEXT_PUBLIC_NAKALCHI_WEB_URL=http://localhost:3001
