# Reference only — the frontend Docker image does NOT read this file at build or run time.
# NEXT_PUBLIC_API_URL is inlined into the client bundle at BUILD time via `docker build
# --build-arg`, sourced from the root .env.production (docker-compose.prod.yml's `frontend.
# build.args`). This file exists for parity with api/worker's .env.production.example and for
# anyone building the frontend image manually outside compose. See DEPLOY.md.

NEXT_PUBLIC_API_URL=https://changeme.duckdns.org/api
